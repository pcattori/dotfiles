// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^git\\s+status(\\s|$)",
            },
            {
              "pattern": "^git\\s+ls\\-files(\\s|$)",
            },
            {
              "pattern": "^pnpm\\b",
            },
            {
              "pattern": "^git\\b",
            },
          ],
        },
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://api\\.github\\.com",
            },
            {
              "pattern": "^https?://raw\\.githubusercontent\\.com",
            },
          ],
        },
      },
    },
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.5",
      "enable_thinking": false,
    },
  },

  "language_models": {
    "anthropic": {
      "api_url": "https://proxy.shopify.ai/v1",
    },
    "openai": {
      "api_url": "https://proxy.shopify.ai/v1",
    },
  },

  "ui_font_family": "MonoLisa Nerd Font",
  "buffer_font_family": "MonoLisa Nerd Font",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Rosé Pine Dawn",
    "dark": "Rosé Pine",
  },
}
